# ---------------------------------------------
# Mongo Express UI
# ---------------------------------------------
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=admin
ME_CONFIG_MONGODB_SERVER=mongo
ME_CONFIG_MONGODB_PORT=27017
ME_CONFIG_MONGODB_ENABLE_ADMIN=true

# ---------------------------------------------
# General
# ---------------------------------------------
TZ=Europe/Rome
NODE_ENV=production

# ---------------------------------------------
# Backend
# ---------------------------------------------
PORT=3000

# ---------------------------------------------
# MongoDB
# ---------------------------------------------
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=nodejs_rag
MONGODB_SESSIONS_COLLECTION=sessions
MONGODB_INTERACTIONS_COLLECTION=interactions
MONGODB_DOCUMENTS_COLLECTION=documents
MONGODB_MQTT_TEMPERATURE_COLLECTION=temperatureEvents
MONGODB_MQTT_HUMIDITY_COLLECTION=humidityEvents

# ---------------------------------------------
# Qdrant
# ---------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents
QDRANT_DISTANCE_METRIC=Cosine

# ---------------------------------------------
# Ollama
# ---------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_HOST=ollama:11434

# ---------------------------------------------
# Chat model
# ---------------------------------------------
CHAT_MODEL=phi4-mini:3.8b
CHAT_MODEL_TEMPERATURE=0.8
CHAT_MODEL_MAX_TOKENS=1024
CHAT_MODEL_TOP_P=0.8
CHAT_MODEL_TOP_K=20
CHAT_MODEL_PRESENCE_PENALTY=1.5
CHAT_MODEL_NUM_CONTEXT=4096

# ---------------------------------------------
# Rewriter model
# ---------------------------------------------
REWRITER_MODEL=phi4-mini:3.8b
REWRITER_MODEL_TEMPERATURE=0.1
REWRITER_MODEL_MAX_TOKENS=128
REWRITER_MODEL_TOP_P=0.8
REWRITER_MODEL_TOP_K=10
REWRITER_MODEL_PRESENCE_PENALTY=0.0
REWRITER_MODEL_NUM_CONTEXT=2048

# ---------------------------------------------
# Embeddings model
# ---------------------------------------------
EMBEDDINGS_MODEL=mxbai-embed-large

# ---------------------------------------------
# RAG pipeline settings
# ---------------------------------------------
N_CHUNK=5
N_HISTORY=5
CHUNK_SCORE_THRESHOLD=0.5

# ---------------------------------------------
# Document ingestion
# ---------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
QDRANT_BATCH=100
MIN_CHUNK_LEN=500
MAX_SPECIAL_RATIO=0.3
ALLOWED_MIME_TYPES=application/pdf,text/plain

# ---------------------------------------------
# MQTT
# ---------------------------------------------
MQTT_URL=mqtt://mosquitto:1883
MQTT_CLIENT_ID=nodejs_rag_backend

# ---------------------------------------------
# Logging
# ---------------------------------------------
LOG_LEVEL=info
